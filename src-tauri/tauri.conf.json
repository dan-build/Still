{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Still",
  "version": "0.1.0",
  "identifier": "com.still.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Still",
        "width": 1100,
        "height": 780,
        "minWidth": 900,
        "minHeight": 650,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Own the silence. Local encrypted secrets, protected by your master password.",
    "longDescription": "Still is a calm, local-first encrypted secret manager. No accounts. Nothing leaves your device. Secrets are encrypted at rest and protected by your master password. Explicitly forget Lenses when you're done.",
    "copyright": "© 2026 Still",
    "publisher": "Still",
    "license": "MIT",
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}